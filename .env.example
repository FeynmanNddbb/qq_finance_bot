# ============================================================
# QQ 财经机器人 - 环境变量配置模板
# ============================================================
# 使用方法：
#   1. 复制本文件为 .env      ->  cp .env.example .env
#   2. 在 .env 中填入你自己的真实密钥（.env 已被 .gitignore 忽略，不会上传）
#   3. 千万不要把真实密钥写进 .env.example 或提交到 GitHub
# ============================================================


# ------------------------------------------------------------
# 一、选择使用哪个大模型来做新闻分析
# ------------------------------------------------------------
# 可选值：zhipu（智谱 GLM） / openai（GPT） / claude（Anthropic Claude）
LLM_PROVIDER=zhipu


# ------------------------------------------------------------
# 二、智谱 AI（GLM）配置    provider=zhipu 时使用
#     申请地址：https://open.bigmodel.cn/
# ------------------------------------------------------------
ZHIPUAI_API_KEY=在这里填入你的智谱APIKey
ZHIPUAI_MODEL=glm-4.6


# ------------------------------------------------------------
# 三、OpenAI / GPT 配置     provider=openai 时使用
#     申请地址：https://platform.openai.com/api-keys
# ------------------------------------------------------------
OPENAI_API_KEY=在这里填入你的OpenAIKey
OPENAI_MODEL=gpt-4o
# 如使用第三方中转/代理服务，填代理地址；官方直连留空即可
OPENAI_BASE_URL=


# ------------------------------------------------------------
# 四、Anthropic Claude 配置  provider=claude 时使用
#     申请地址：https://console.anthropic.com/
# ------------------------------------------------------------
ANTHROPIC_API_KEY=在这里填入你的ClaudeKey
ANTHROPIC_MODEL=claude-opus-4-8


# ------------------------------------------------------------
# 五、NapCat（QQ 机器人 HTTP 接口）配置
# ------------------------------------------------------------
# NapCat HTTP API 地址（通常是 3000 端口）
NAPCAT_HTTP=http://127.0.0.1:3000
# 在 NapCat WebUI 中设置的 Access Token；没有设置则留空
NAPCAT_TOKEN=在这里填入你的NapCatToken
# 目标 QQ 群号
QQ_GROUP_ID=在这里填入你的群号


# ------------------------------------------------------------
# 六、可选：只启用部分新闻源（逗号分隔），留空则启用全部
#     可选：cls,wallstreet,csrc,nfra
# ------------------------------------------------------------
NEWS_SOURCES=
