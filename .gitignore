*.key

# ===== Python 虚拟环境（本项目目录本身就是 venv）=====
Lib/
Scripts/
Include/
pyvenv.cfg
bin/
lib/
lib64/

# ===== Python 缓存与构建产物 =====
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
build/
dist/

# ===== 日志（可能含群号等信息）=====
logs/
*.log

# ===== 第三方大文件 / 运行时（自行下载，不入库）=====
NapCat.Shell.Windows.OneKey/
*.zip

# ===== 抓取到的本地网页快照 =====
res/

# ===== 编辑器 / IDE =====
.idea/
